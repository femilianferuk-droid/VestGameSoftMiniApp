# PostgreSQL DSN. Совпадает с тем, что использует бот.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Токен Telegram-бота (тот же, что в bot.py).
BOT_TOKEN=your-telegram-bot-token

# Секрет для подписи cookie-сессий. ОБЯЗАТЕЛЬНО смени в проде.
FLASK_SECRET_KEY=please-change-me-to-something-random

# Максимальный возраст initData (секунды). 3600 = 1 час.
INIT_DATA_TTL_SECONDS=3600

# Порт Flask.
PORT=8080
